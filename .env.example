# Copy to .env and fill in your Supabase project values.
# Both are safe to expose in the browser (the publishable/anon key is public).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Password to view the "Results history" screen. This ships in the client
# bundle, so treat it as a casual gate (keeps casual students out), not real
# authentication.
VITE_RESULTS_PASSWORD=choose-a-password
